<Window
    x:Class="RomesteadSaveInspector.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:RomesteadSaveInspector.WinUI"
    mc:Ignorable="d"
    Title="Romestead Save Inspector">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="8" Padding="16,12,16,8">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="300" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock x:Name="TitleText" Text="Romestead Save Inspector - WinUI 3" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock x:Name="SubtitleText" Text="Inspect, edit player item stack counts, back up before saving, and copy saved files to output." TextWrapping="Wrap" Opacity="0.78" />
                </StackPanel>
                <TextBlock x:Name="LanguageLabel" Grid.Column="1" Text="Language" VerticalAlignment="Center" Margin="0,0,2,0" />
                <ComboBox x:Name="LanguageBox" Grid.Column="2" MinWidth="220" SelectionChanged="LanguageBox_SelectionChanged" VerticalAlignment="Center">
                    <ComboBoxItem Tag="zh-Hans" Content="简体中文" />
                    <ComboBoxItem Tag="zh-Hant" Content="繁體中文" />
                    <ComboBoxItem Tag="de" Content="Deutsch" />
                    <ComboBoxItem Tag="es" Content="Español" />
                    <ComboBoxItem Tag="fr" Content="Français" />
                    <ComboBoxItem Tag="pl" Content="Polski" />
                    <ComboBoxItem Tag="pt-BR" Content="Português (Brasil)" />
                    <ComboBoxItem Tag="ru" Content="Русский" />
                    <ComboBoxItem Tag="ja" Content="日本語" />
                    <ComboBoxItem Tag="tr" Content="Türkçe" />
                    <ComboBoxItem Tag="ko" Content="한국어" />
                    <ComboBoxItem Tag="en" Content="English" />
                </ComboBox>
                <Border Grid.Column="3" Padding="10,8" CornerRadius="10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" VerticalAlignment="Center">
                    <StackPanel Spacing="2">
                        <TextBlock x:Name="InformationTitle" Text="Information" FontWeight="SemiBold" />
                        <TextBlock x:Name="InfoVersionText" Text="Version: R1.0" TextWrapping="NoWrap" />
                        <TextBlock x:Name="InfoDateText" Text="Date: 26/5/27" TextWrapping="NoWrap" />
                        <TextBlock x:Name="InfoGameVersionText" Text="Game version: 0.25.1_1" TextWrapping="NoWrap" />
                        <TextBlock x:Name="InfoAuthorText" Text="Author: Maple5335" TextWrapping="NoWrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="10" CornerRadius="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="Step1Title" Text="Step 1: Prepare dependency DLLs" FontSize="16" FontWeight="SemiBold" />
                        <Button Content="?" Width="32" Click="HelpDll_Click" />
                    </StackPanel>
                    <TextBlock x:Name="Step1Description" Grid.Row="1" Text="Manually copy *.dll from the Romestead game folder into this tool's lib folder." TextWrapping="Wrap" />
                    <Button x:Name="OpenLibButton" Grid.Row="2" Content="Open lib folder" MinWidth="150" HorizontalAlignment="Left" Click="OpenLib_Click" />
                </Grid>
            </Border>

            <Border Padding="10" CornerRadius="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="Step2Title" Text="Step 2: Add save files" FontSize="16" FontWeight="SemiBold" />
                        <Button Content="?" Width="32" Click="HelpSaveFiles_Click" />
                    </StackPanel>
                    <TextBlock x:Name="Step2Description" Grid.Row="1" Text="Copy world_desc and username.char into the input folder. You can open the game save directory first and copy them manually." TextWrapping="Wrap" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                        <Button x:Name="OpenProfilesButton" Content="Open game save directory" MinWidth="260" Padding="16,8" Click="OpenProfiles_Click" />
                        <Button x:Name="OpenInputButton" Content="Open input folder" MinWidth="160" Padding="16,8" Click="OpenInput_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Padding="10" CornerRadius="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="Step3Title" Text="Step 3: Inspect and save" FontSize="16" FontWeight="SemiBold" />
                        <Button Content="?" Width="32" Click="HelpWorkflow_Click" />
                    </StackPanel>
                    <StackPanel Grid.Row="1" Spacing="8">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="340" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="UserNameLabel" Grid.Column="0" Text="User name" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" x:Name="PlayerNameBox" PlaceholderText="Enter user name, without .char" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="CheckFilesButton" Content="Check files" MinWidth="120" Click="CheckFiles_Click" />
                            <Button x:Name="InspectButton" Content="Inspect" MinWidth="120" Click="Inspect_Click" />
                            <Button x:Name="SaveButton" Content="Save player items" MinWidth="170" Click="Save_Click" />
                        </StackPanel>
                    </StackPanel>
                    <InfoBar Grid.Row="2" x:Name="StatusBar" IsOpen="True" Severity="Informational" Title="Status" Message="Ready." />
                </Grid>
            </Border>
        </StackPanel>

        <Grid Grid.Row="1" Padding="16,8,16,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="1.4*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="WorldInfoTitle" Grid.Row="0" Text="World information" FontSize="18" FontWeight="SemiBold" />
                <ListView Grid.Row="1" ItemsSource="{x:Bind WorldRows, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:KeyValueRow">
                            <Grid ColumnSpacing="10" Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Key}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Value}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="PlayerTotalsTitle" Grid.Row="2" Text="Player item totals" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                <ListView Grid.Row="3" ItemsSource="{x:Bind PlayerTotals, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:KeyValueRow">
                            <Grid ColumnSpacing="10" Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="90" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Key}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{x:Bind Value}" HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock x:Name="PlayerItemsTitle" Grid.Row="0" Text="Player items (StackCount editable)" FontSize="18" FontWeight="SemiBold" />
                <Grid Grid.Row="1" Padding="6" ColumnSpacing="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="110" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderSection" Grid.Column="0" Text="Section" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderSlot" Grid.Column="1" Text="Slot" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderBaseDataId" Grid.Column="2" Text="Item ID" FontWeight="SemiBold" />
                    <TextBlock x:Name="HeaderStackCount" Grid.Column="3" Text="Count" FontWeight="SemiBold" />
                </Grid>
                <ListView Grid.Row="2" ItemsSource="{x:Bind PlayerItems, Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:PlayerItemRow">
                            <Grid Padding="6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="110" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{x:Bind Section}" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="1" Text="{x:Bind SlotIndex}" />
                                <TextBlock Grid.Column="2" Text="{x:Bind BaseDataId}" TextTrimming="CharacterEllipsis" />
                                <TextBox Grid.Column="3" Text="{x:Bind StackCountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Padding="16,0,16,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="DebugLogTitle" Grid.Row="0" Text="Debug log (shown by default)" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,6" />
            <TextBox Grid.Row="1" x:Name="LogBox" IsReadOnly="True" TextWrapping="NoWrap" AcceptsReturn="True" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" />
        </Grid>
    </Grid>
</Window>
